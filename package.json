{
  "name": "fakturio",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n WEB,WORKER -c green,cyan \"npm:dev:web\" \"npm:dev:worker\"",
    "dev:web": "npm run dev -w @fakturio/web",
    "dev:worker": "npm run dev -w @fakturio/worker",
    "build": "npm run prisma:generate && npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "prisma:generate": "npm run db:generate",
    "db:migrate": "prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "db:studio": "prisma studio --schema packages/db/prisma/schema.prisma"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.956.0",
    "@aws-sdk/client-sesv2": "^3.956.0",
    "@aws-sdk/s3-request-presigner": "^3.956.0",
    "@prisma/client": "^6.19.0",
    "@temporalio/activity": "^1.18.0",
    "@temporalio/client": "^1.18.0",
    "@temporalio/common": "^1.18.0",
    "@temporalio/worker": "^1.18.0",
    "@temporalio/workflow": "^1.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "mailparser": "^3.9.9",
    "next": "^16.2.7",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^7.0.13",
    "openai": "^6.9.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@temporalio/testing": "^1.18.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "postcss": "^8.5.6",
    "prisma": "^6.19.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  }
}
