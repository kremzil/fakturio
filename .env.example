DATABASE_URL="postgresql://fakturio:fakturio@localhost:5432/fakturio?schema=public"
AUTH_SECRET="replace-with-32-plus-random-characters"
AUTH_TRUST_HOST=true
NEXTAUTH_URL="http://localhost:3000"

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1"
MOCK_AI=1

TEMPORAL_ADDRESS="localhost:7233"
TEMPORAL_NAMESPACE="default"
TEMPORAL_TASK_QUEUE="fakturio-collection"

STORAGE_DRIVER="s3"
AWS_REGION="eu-central-1"
AWS_S3_BUCKET="fakturio-local"
AWS_ACCESS_KEY_ID="fakturio"
AWS_SECRET_ACCESS_KEY="fakturio-secret"
AWS_S3_ENDPOINT="http://localhost:9000"
AWS_S3_FORCE_PATH_STYLE=1

EMAIL_DRIVER="mailpit"
MAILPIT_API_URL="http://localhost:8025"
MAILPIT_SMTP_HOST="localhost"
MAILPIT_SMTP_PORT=1025
SES_FROM_EMAIL="system@example.com"
SES_INBOUND_BUCKET="fakturio-inbound-mail"

# Secret used to sign payment-check links in collection emails (HMAC-SHA256).
# Generate once: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# MUST be identical in apps/web and apps/worker (worker signs, web verifies).
# Required in production; in development a built-in dev fallback is used if unset.
# Rotating this value invalidates all previously emailed payment-check links.
PAYMENT_CHECK_TOKEN_SECRET="replace-with-32-plus-random-characters"
# Lifetime (in days) of payment-check links. Read by the worker when signing.
# Defaults to 30 if unset. Only affects newly sent emails; existing links keep their original expiry.
PAYMENT_CHECK_TOKEN_TTL_DAYS=7
