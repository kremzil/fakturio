generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model InvoiceUpload {
  id         String   @id @default(cuid())
  userId     String
  filePath   String
  fileName   String
  fileType   String
  fileSize   Int
  status     String
  parseError String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  invoice   Invoice?
  actionLog InvoiceActionLog[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Invoice {
  id       String @id @default(cuid())
  uploadId String @unique
  userId   String

  invoiceNumber String?
  issueDate     DateTime?
  dueDate       DateTime?
  amountTotal   Float?
  currency      String?

  supplierName    String?
  supplierIco     String?
  supplierDic     String?
  supplierIcDph   String?
  supplierAddress String?

  debtorName    String?
  debtorIco     String?
  debtorDic     String?
  debtorIcDph   String?
  debtorAddress String?

  iban           String?
  variableSymbol String?
  constantSymbol String?
  specificSymbol String?

  subjectNote     String?
  rawAiResult     String?
  aiConfidence    Float?
  warnings        String?
  confirmedByUser String?
  confirmedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  upload    InvoiceUpload      @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  actionLog InvoiceActionLog[]

  @@index([userId])
  @@index([invoiceNumber])
  @@index([dueDate])
  @@index([createdAt])
}

model InvoiceActionLog {
  id        String   @id @default(cuid())
  invoiceId String?
  uploadId  String?
  actorType String
  actorId   String?
  action    String
  note      String?
  createdAt DateTime @default(now())

  invoice Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  upload  InvoiceUpload? @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([uploadId])
  @@index([action])
  @@index([createdAt])
}
